generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Extensible Role System ────────────────────────────────────────────

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]

  @@map("roles")
}

// ─── User ──────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdCampaigns Campaign[]
  assignedPosts    Post[]

  @@map("users")
}

// ─── Campaign Status (Extensible) ──────────────────────────────────────

model CampaignStatus {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  createdAt   DateTime   @default(now())
  campaigns   Campaign[]

  @@map("campaign_statuses")
}

// ─── Campaign ──────────────────────────────────────────────────────────

model Campaign {
  id          String         @id @default(uuid())
  title       String
  description String?
  statusId    String
  status      CampaignStatus @relation(fields: [statusId], references: [id])
  createdById String
  createdBy   User           @relation(fields: [createdById], references: [id])
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  posts       Post[]

  @@map("campaigns")
}

// ─── Post Status (Extensible) ──────────────────────────────────────────

model PostStatus {
  id           String   @id @default(uuid())
  name         String   @unique
  displayOrder Int      @default(0)
  description  String?
  createdAt    DateTime @default(now())
  posts        Post[]

  @@map("post_statuses")
}

// ─── Post ──────────────────────────────────────────────────────────────

model Post {
  id           String     @id @default(uuid())
  content      String
  campaignId   String
  campaign     Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  assignedToId String?
  assignedTo   User?      @relation(fields: [assignedToId], references: [id])
  statusId     String
  status       PostStatus @relation(fields: [statusId], references: [id])
  dueDate      DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("posts")
}
