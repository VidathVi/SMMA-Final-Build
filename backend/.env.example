# Server
PORT=8080
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/orean360
JWT_SECRET=your_jwt_secret_here

# Redis (for BullMQ task queues)
REDIS_URL=redis://localhost:6379
ENABLE_WORKERS=true

# GEO Engine (AI Content Generation)
FASTAPI_URL=http://localhost:8000
GEO_ENGINE_URL=http://localhost:11434/api/generate

# Media Transcoding
TRANSCODED_OUTPUT_DIR=./transcoded

# Google OAuth (accounts.google.com)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Frontend URL (for OAuth redirects)
FRONTEND_URL=http://localhost:3000

# YouTube API (Google Cloud Console > APIs & Services > Credentials)
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret
YOUTUBE_REDIRECT_URI=http://localhost:8080/api/youtube/callback

# Meta (Facebook/Instagram) Graph API (developers.facebook.com)
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_REDIRECT_URI=http://localhost:8080/api/meta/callback

# WhatsApp Business API (Meta Business Suite)
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_whatsapp_business_account_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_VERIFY_TOKEN=orean360_whatsapp_verify
WHATSAPP_PHONE_NUMBER=your_whatsapp_phone_number

# LinkedIn API (linkedin.com/developers)
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_REDIRECT_URI=http://localhost:8080/api/linkedin/callback

# TikTok API (developers.tiktok.com)
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_REDIRECT_URI=http://localhost:8080/api/tiktok/callback
