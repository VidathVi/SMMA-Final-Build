FROM node:20-slim

RUN apt-get update && apt-get install -y ffmpeg openssl && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package*.json ./

RUN npm ci

COPY prisma/ ./prisma/

RUN npx prisma generate

COPY tsconfig.json ./
COPY src/ ./src/

RUN npm run build

RUN npm prune --omit=dev

RUN addgroup --system appgroup && \
    adduser --system --shell /bin/false --no-create-home --ingroup appgroup appuser

USER appuser

EXPOSE 8080

CMD ["node", "dist/src/server.js"]